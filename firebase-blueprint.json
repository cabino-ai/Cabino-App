{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A cabinet visualization project",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "roomImage": { "type": "string" },
        "generatedPrompt": { "type": "string" },
        "generatedImage": { "type": "string" },
        "extendToCeiling": { "type": "boolean" },
        "stageRoom": { "type": "boolean" },
        "masterPrompt": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "roomImage", "createdAt"]
    },
    "Cabinet": {
      "title": "Cabinet",
      "description": "A cabinet sample image",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "image"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/checkout_sessions/{sessionId}": {
      "schema": { "type": "object" },
      "description": "Stripe checkout sessions"
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": { "type": "object" },
      "description": "Stripe subscriptions"
    },
    "/users/{userId}/payments/{paymentId}": {
      "schema": { "type": "object" },
      "description": "Stripe payments"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/projects/{projectId}/cabinets/{cabinetId}": {
      "schema": "Cabinet",
      "description": "Cabinet samples for a project"
    }
  }
}
